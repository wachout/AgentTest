  <graph edgedefault="undirected">
    <node id="流浪地球">
      <data key="d0">流浪地球</data>
      <data key="d1">Content</data>
      <data key="d2">《流浪地球》是刘慈欣创作的科幻小说，讲述了人类为了生存而启动的“流浪地球”计划。</data>
      <data key="d3">chunk-81923ba451c8105558b3e33b2238ddfd</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1758338661</data>
    </node>
    <node id="刘慈欣">
      <data key="d0">刘慈欣</data>
      <data key="d1">Person</data>
      <data key="d2">刘慈欣是《流浪地球》这部科幻小说的作者。</data>
      <data key="d3">chunk-81923ba451c8105558b3e33b2238ddfd</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1758338661</data>
    </node>
    <node id="太阳">
      <data key="d0">太阳</data>
      <data key="d1">Naturalobject</data>
      <data key="d2">太阳即将发生氦闪，威胁到太阳系的生存。</data>
      <data key="d3">chunk-81923ba451c8105558b3e33b2238ddfd</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1758338661</data>
    </node>
    <node id="太阳系">
      <data key="d0">太阳系</data>
      <data key="d1">Location</data>
      <data key="d2">太阳系是地球所在的星系，因太阳即将氦闪而面临毁灭。</data>
      <data key="d3">chunk-81923ba451c8105558b3e33b2238ddfd</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1758338661</data>
    </node>
    <node id="半人马座比邻星">
      <data key="d0">半人马座比邻星</data>
      <data key="d1">Location</data>
      <data key="d2">半人马座比邻星是地球计划前往的新星系，距离地球约4.2光年。</data>
      <data key="d3">chunk-81923ba451c8105558b3e33b2238ddfd</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1758338661</data>
    </node>
    <node id="行星发动机">
      <data key="d0">行星发动机</data>
      <data key="d1">Artifact</data>
      <data key="d2">行星发动机是建造在地球表面的巨大装置，用于推动地球离开太阳系。</data>
      <data key="d3">chunk-81923ba451c8105558b3e33b2238ddfd</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1758338661</data>
    </node>
