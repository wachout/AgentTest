  <graph edgedefault="undirected">
    <node id="流浪地球">
      <data key="d0">流浪地球</data>
      <data key="d1">Content</data>
      <data key="d2">《流浪地球》是刘慈欣创作的科幻小说，讲述了人类为了生存而启动的“流浪地球”计划。</data>
      <data key="d3">chunk-f8c1c8684ce0bec748240ccfd5fda56b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1758521118</data>
    </node>
    <node id="刘慈欣">
      <data key="d0">刘慈欣</data>
      <data key="d1">Person</data>
      <data key="d2">刘慈欣是《流浪地球》的作者，是一位科幻小说作家。</data>
      <data key="d3">chunk-f8c1c8684ce0bec748240ccfd5fda56b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1758521118</data>
    </node>
    <node id="太阳">
      <data key="d0">太阳</data>
      <data key="d1">Naturalobject</data>
      <data key="d2">太阳即将氦闪，对太阳系构成威胁，促使人类启动了“流浪地球”计划。</data>
      <data key="d3">chunk-f8c1c8684ce0bec748240ccfd5fda56b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1758521118</data>
    </node>
    <node id="太阳系">
      <data key="d0">太阳系</data>
      <data key="d1">Location</data>
      <data key="d2">太阳系是地球原本所在的星系，由于太阳即将氦闪而面临毁灭。</data>
      <data key="d3">chunk-f8c1c8684ce0bec748240ccfd5fda56b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1758521118</data>
    </node>
    <node id="半人马座比邻星">
      <data key="d0">半人马座比邻星</data>
      <data key="d1">Location</data>
      <data key="d2">半人马座比邻星是地球在“流浪地球”计划中的目的地，预计需要2500年的星际旅行才能到达。</data>
      <data key="d3">chunk-f8c1c8684ce0bec748240ccfd5fda56b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1758521118</data>
    </node>
    <node id="行星发动机">
      <data key="d0">行星发动机</data>
      <data key="d1">Artifact</data>
      <data key="d2">行星发动机是在地球表面建造的一万座巨大的发动机，用于推动地球离开太阳系。</data>
      <data key="d3">chunk-f8c1c8684ce0bec748240ccfd5fda56b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1758521118</data>
    </node>
    <node id="国际空间站">
      <data key="d0">国际空间站</data>
      <data key="d1">Artifact</data>
      <data key="d2">国际空间站是刘培强工作的场所，他是一名宇航员。</data>
      <data key="d3">chunk-f8c1c8684ce0bec748240ccfd5fda56b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1758521118</data>
    </node>
    <node id="刘启">
      <data key="d0">刘启</data>
      <data key="d1">Person</data>
      <data key="d2">刘启是《流浪地球》的主角，是一名年轻的航天员，他的父亲是刘培强。</data>
      <data key="d3">chunk-f8c1c8684ce0bec748240ccfd5fda56b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1758521118</data>
    </node>
    <node id="刘培强">
      <data key="d0">刘培强</data>
      <data key="d1">Person</data>
      <data key="d2">刘培强是刘启的父亲，是国际空间站的宇航员，在木星引力危机中做出了巨大牺牲。</data>
      <data key="d3">chunk-f8c1c8684ce0bec748240ccfd5fda56b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1758521119</data>
    </node>
    <node id="木星">
      <data key="d0">木星</data>
      <data key="d1">Naturalobject</data>
      <data key="d2">木星是地球在星际旅行中遇到的一个重要天体，其引力危机对地球构成了威胁。</data>
      <data key="d3">chunk-f8c1c8684ce0bec748240ccfd5fda56b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1758521119</data>
    </node>
    <node id="氦闪">
      <data key="d0">氦闪</data>
      <data key="d1">Concept</data>
      <data key="d2">氦闪是太阳即将发生的一种现象，对太阳系构成威胁。</data>
      <data key="d3">chunk-f8c1c8684ce0bec748240ccfd5fda56b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1758521119</data>
    </node>
