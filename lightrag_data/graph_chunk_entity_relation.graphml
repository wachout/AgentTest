      <data key="d1">Artifact</data>
      <data key="d2">国际空间站是刘培强工作的地点，他是一名宇航员。</data>
      <data key="d3">chunk-81923ba451c8105558b3e33b2238ddfd</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1758513035</data>
    </node>
    <node id="刘启">
      <data key="d0">刘启</data>
      <data key="d1">Person</data>
      <data key="d2">刘启是故事的主角，是一名年轻的航天员。</data>
